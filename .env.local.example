# ============================================================
# HQS Imobiliare — Variabile de mediu necesare
# Copiaza acest fisier in .env.local si completeaza valorile.
# Nu comite niciodata .env.local in git!
# ============================================================

# --- Supabase (obligatorii) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Admin (obligatorii pentru panoul de administrare) ---
# Emailuri separate prin virgula care primesc acces bootstrap admin
ADMIN_BOOTSTRAP_EMAILS=admin@hqsimobiliare.ro

# --- Integrari optionale ---
RESEND_API_KEY=re_your_key
TWILIO_ACCOUNT_SID=AC_your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_FROM_PHONE=+40xxxxxxxxx
GOOGLE_CALENDAR_CREDENTIALS={"client_email":"...","private_key":"...","calendar_id":"..."}
DOCUSIGN_INTEGRATION_KEY=your_key
DOCUSIGN_ACCOUNT_ID=your_account_id
DOCUSIGN_PRIVATE_KEY=your_private_key
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://hqsimobiliare.ro
