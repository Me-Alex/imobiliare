{
  "name": "hqs-imobiliare",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "typecheck": "tsc --noEmit",
    "build": "next build",
    "pages:build": "node scripts/cloudflare-pages-build.mjs",
    "cloudflare:build": "npm run pages:build",
    "worker:build": "opennextjs-cloudflare build",
    "worker:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "worker:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "audit:prod": "npm audit --omit=dev",
    "smoke:live": "node scripts/smoke-live.mjs",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "verify": "npm run typecheck && npm run test && npm run build",
    "start": "next start"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.1",
    "lucide-react": "1.14.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.14.10",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.6",
    "wrangler": "4.59.2"
  }
}
